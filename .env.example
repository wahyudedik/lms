# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

APP_NAME="Learning Management System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com

# Localization
APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_TIMEZONE=Asia/Jakarta

# Maintenance Mode
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP Configuration
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# =============================================================================
# LOGGING
# =============================================================================

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# =============================================================================
# DATABASE
# =============================================================================

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lms_production
DB_USERNAME=lms_user
DB_PASSWORD=

# Queue Database Connection (optional, defaults to DB_CONNECTION)
# DB_QUEUE_CONNECTION=
# DB_QUEUE_TABLE=jobs
# DB_QUEUE=default
# DB_QUEUE_RETRY_AFTER=90

# =============================================================================
# SESSION
# =============================================================================

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PARTITIONED_COOKIE=false
# SESSION_CONNECTION=
# SESSION_TABLE=sessions
# SESSION_STORE=

# =============================================================================
# CACHE & QUEUE
# =============================================================================

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
# CACHE_PREFIX=

# =============================================================================
# REDIS (Optional - for better performance)
# =============================================================================

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# REDIS_QUEUE_CONNECTION=default
# REDIS_QUEUE=default
# REDIS_QUEUE_RETRY_AFTER=90

# =============================================================================
# MEMCACHED (Optional)
# =============================================================================

MEMCACHED_HOST=127.0.0.1

# =============================================================================
# MAIL CONFIGURATION
# =============================================================================

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Alternative Mail Services
# POSTMARK_TOKEN=
# RESEND_KEY=

# =============================================================================
# AWS SERVICES (Optional - for S3 storage, SES email)
# =============================================================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# =============================================================================
# AI ASSISTANT (Multi-Provider: OpenAI, Anthropic, Google Gemini)
# =============================================================================

# AI Provider: openai | anthropic | gemini
# (Managed via admin settings panel, key: ai_provider)
# AI_PROVIDER=openai

# OpenAI API Configuration
OPENAI_API_KEY=
# Anthropic (Claude) API Key (managed via admin settings, key: ai_anthropic_api_key)
# ANTHROPIC_API_KEY=
# Google Gemini API Key (managed via admin settings, key: ai_gemini_api_key)
# GEMINI_API_KEY=

# Model selection (must match the active provider)
# OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-4, gpt-3.5-turbo
# Anthropic: claude-sonnet-4-20250514, claude-3-5-sonnet-20241022, claude-3-5-haiku-20241022, claude-3-opus-20240229
# Gemini: gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.7

# AI Feature Toggle (managed via admin settings, but can be set here)
# AI_ENABLED=false

# =============================================================================
# CERTIFICATE SYSTEM
# =============================================================================

# Certificate Template: default, modern, elegant, minimalist
CERTIFICATE_TEMPLATE=default

# Institution Information
CERTIFICATE_INSTITUTION_NAME="Your Institution Name"
CERTIFICATE_LOGO_PATH=
CERTIFICATE_DIRECTOR_NAME="Director Name"

# Certificate Colors (hex codes)
CERTIFICATE_PRIMARY_COLOR=#3b82f6
CERTIFICATE_SECONDARY_COLOR=#8b5cf6
CERTIFICATE_ACCENT_COLOR=#ec4899
CERTIFICATE_TEXT_COLOR=#1e293b

# Certificate Features
CERTIFICATE_AUTO_GENERATE=true
CERTIFICATE_NOTIFY_STUDENT=true
CERTIFICATE_QR_CODE=true
CERTIFICATE_AUTO_SAVE=true
CERTIFICATE_EMAIL_ENABLED=false

# Certificate Storage
CERTIFICATE_STORAGE_DISK=public

# =============================================================================
# PWA (Progressive Web App)
# =============================================================================

PWA_ENABLED=true

# =============================================================================
# THIRD-PARTY SERVICES
# =============================================================================

# Slack Notifications (Optional)
# SLACK_BOT_USER_OAUTH_TOKEN=
# SLACK_BOT_USER_DEFAULT_CHANNEL=

# =============================================================================
# VITE (Frontend Build Tool)
# =============================================================================

VITE_APP_NAME="${APP_NAME}"
